                <action android:name="com.example.rungps.WIDGET_REST_120"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/gym_widget_info"/>
        </receiver>
        <receiver
            android:label="@string/ride_run_widget_label"
            android:name="com.example.rungps.widget.RideRunWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/ride_run_widget_info"/>
        </receiver>
