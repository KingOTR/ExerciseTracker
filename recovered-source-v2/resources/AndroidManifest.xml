            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
            </intent-filter>
        </receiver>
        <receiver
            android:name="com.example.rungps.sleep.BedtimeReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.rungps.sleep.BEDTIME_REMINDER"/>
            </intent-filter>
        </receiver>
        <receiver
            android:name="com.example.rungps.notify.RestTimerReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.rungps.REST_TIMER_DONE"/>
            </intent-filter>
        </receiver>
        <receiver
            android:name="com.example.rungps.notify.NotificationDismissReceiver"
            android:exported="false">
