<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/widget_root"
    android:background="@drawable/widget_background_recovery"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_widget_recovery"
            android:contentDescription="@string/recovery_widget_label"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary"
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recovery_widget_label"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/widget_text_muted"
                android:id="@+id/widget_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recovery_widget_brand"/>
        </LinearLayout>
        <TextView
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/widget_readiness_caution"
            android:id="@+id/widget_readiness_badge"
            android:background="@drawable/widget_readiness_badge_caution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"/>
    </LinearLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/widget_text_primary"
        android:ellipsize="end"
        android:id="@+id/widget_advice_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/recovery_widget_default_advice"
        android:maxLines="2"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/widget_text_secondary"
        android:id="@+id/widget_last_gym_line"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/widget_text_secondary"
        android:ellipsize="end"
        android:id="@+id/widget_recovery_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/recovery_widget_default_recovery"
        android:maxLines="1"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/widget_text_muted"
        android:id="@+id/widget_cta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/recovery_widget_open"/>
</LinearLayout>
