<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/widget_root"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_widget_gym"
            android:contentDescription="@string/gym_widget_label"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary"
                android:ellipsize="end"
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/gym_widget_label"
                android:maxLines="1"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/widget_text_muted"
                android:id="@+id/widget_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/gym_widget_brand"/>
        </LinearLayout>
        <TextView
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:id="@+id/widget_badge"
            android:background="@drawable/widget_badge_active"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gym_widget_badge_active"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/widget_attendance_block"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/widget_accent_gold"
                android:id="@+id/widget_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/widget_text_secondary"
                android:id="@+id/widget_days_stat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/widget_progress"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progressDrawable="@drawable/widget_progress_layer"
            style="?android:attr/progressBarStyleHorizontal"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">
            <TextView
                android:textSize="10sp"
                android:textColor="@color/widget_text_secondary"
                android:id="@+id/widget_streak"
                android:background="@drawable/widget_stat_chip"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/widget_text_secondary"
                android:id="@+id/widget_days_left"
                android:background="@drawable/widget_stat_chip"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/widget_text_secondary"
                android:id="@+id/widget_trend"
                android:background="@drawable/widget_stat_chip"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/widget_text_primary"
        android:ellipsize="end"
        android:id="@+id/widget_exercise"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"/>
    <TextView
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/widget_accent_gold"
        android:id="@+id/widget_status"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/widget_text_secondary"
        android:ellipsize="end"
        android:id="@+id/widget_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/gym_widget_tap_hint"
        android:maxLines="2"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/widget_rest_row"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:gravity="center"
            android:id="@+id/widget_rest_60"
            android:background="@drawable/widget_rest_chip"
            android:padding="8dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="60s"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:gravity="center"
            android:id="@+id/widget_rest_90"
            android:background="@drawable/widget_rest_chip"
            android:padding="8dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="90s"
            android:layout_weight="1"
            android:layout_marginStart="6dp"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:gravity="center"
            android:id="@+id/widget_rest_120"
            android:background="@drawable/widget_rest_chip"
            android:padding="8dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2m"
            android:layout_weight="1"
            android:layout_marginStart="6dp"/>
    </LinearLayout>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/widget_text_muted"
        android:id="@+id/widget_cta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/gym_widget_open"/>
</LinearLayout>
